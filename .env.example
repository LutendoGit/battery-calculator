# ============================================================================
# Flask Configuration
# ============================================================================
# SECRET_KEY: Required for session management and CSRF protection
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 characters
SECRET_KEY=your-secret-key-here-min-32-chars-change-this-in-production

# FLASK_ENV: Set to 'production' when deployed
# production = Optimized, no debug mode, less verbose logging
# development = Debug mode, auto-reload, verbose logging
FLASK_ENV=production

# FLASK_DEBUG: MUST be 0 in production (exposes internal state)
FLASK_DEBUG=0

# ============================================================================
# Admin Settings
# ============================================================================
# ADMIN_STREAM_TOKEN: Required for admin dashboard access
# Generate with: python -c "import secrets; print('sP1KYXbw3fS2ZYF5LmJF3Qr-TOdf0' + secrets.token_hex(32))"
# Usage: Access /learn/admin/users?token=YOUR_TOKEN or header X-Admin-Token: YOUR_TOKEN
# ROTATE THIS TOKEN PERIODICALLY AND KEEP IT SECRET
ADMIN_STREAM_TOKEN=your-secure-admin-token-here-min-64-chars

# ============================================================================
# Database Configuration
# ============================================================================
# LOCAL DEVELOPMENT:
#   DATABASE_URL=sqlite:///./data/education.db
# 
# RENDER DEPLOYMENT (with persistent disk at /data):
#   DATABASE_URL=/data/education.db
#
# PostgreSQL (if migrating):
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./data/education.db

# ============================================================================
# Maintenance Mode
# ============================================================================
# Set to 'true' to display maintenance page instead of serving the app
# Useful for database migrations or major updates
# Values: 'true', '1', 'yes', 'on' (case-insensitive)
MAINTENANCE_MODE=false

# Time to ask clients to retry (in seconds or HTTP-date format)
MAINTENANCE_RETRY_AFTER=300

# ============================================================================
# Frontend Configuration
# ============================================================================
# Base URL for API calls in the frontend
# LOCAL: http://localhost:5000
# PRODUCTION: https://your-app.onrender.com
VITE_API_BASE_URL=http://localhost:5000

# Application name displayed in UI
VITE_APP_NAME=Battery Calculator

# Version for cache-busting
VITE_VERSION=1.0.0

# ============================================================================
# Logging Configuration (Optional)
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# ============================================================================
# Security Settings
# ============================================================================
# HSTS (HTTP Strict Transport Security) max age in seconds
# 31536000 = 1 year
# HSTS_MAX_AGE=31536000

# Enable CORS for specific origins (comma-separated)
# CORS_ORIGINS=https://example.com,https://app.example.com

# ============================================================================
# IMPORTANT: Deployment Instructions
# ============================================================================
# 1. Copy this file to .env in your project root:
#    cp .env.example .env
#
# 2. Update all values marked "your-..." with actual values
#
# 3. For Render deployment:
#    - DO NOT commit .env file (add to .gitignore)
#    - Set SECRET_KEY and ADMIN_STREAM_TOKEN in Render Dashboard:
#      Environment → Environment Variables
#    - Commit .env.example to version control (for reference)
#
# 4. Generate secure values:
#    python -c "import secrets; print(secrets.token_hex(32))"
#
# 5. Never commit sensitive data (tokens, keys, passwords)
#
# 6. Rotate ADMIN_STREAM_TOKEN every 90 days
# ============================================================================


# Optional: Render/Deployment
PYTHON_VERSION=3.11
PYTHONUNBUFFERED=1
